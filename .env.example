# Пример переменных окружения для Next.js.
# Добавляйте сюда только те переменные, которые реально используются в проекте.
# Например:
# NEXT_PUBLIC_API_URL="https://api.example.com"
NEXT_PUBLIC_SITE_URL="https://www.bober-ai.dev"
# White-label partner landing (partners.bober-ai.dev → /white-label via Caddy host rewrite)
NEXT_PUBLIC_PARTNERS_SITE_URL="https://partners.bober-ai.dev"
# Bitrix24 + amoCRM landing (bitrix.bober-ai.dev → /bitrix via Caddy host rewrite)
NEXT_PUBLIC_BITRIX_SITE_URL="https://bitrix.bober-ai.dev"
NEXT_PUBLIC_YANDEX_METRIKA_ID="110635302"
NEXT_PUBLIC_PARTNERS_YANDEX_METRIKA_ID="110926696"
NEXT_PUBLIC_BITRIX_YANDEX_METRIKA_ID="110926887"
# Публичный email на сайте (mailto, футер, Schema):
NEXT_PUBLIC_CONTACT_EMAIL="contact@bober-ai.dev"

# Форма заявки (SMTP)
# Пример для Selectel SMTP relay:
#   SMTP_HOST="smtp.mail.selcloud.ru"
#   SMTP_PORT="1127"
#   SMTP_SECURE="1"
#   SMTP_USER="..."
#   SMTP_PASS="..."
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="1"
SMTP_USER=""
SMTP_PASS=""
CONTACT_FROM_EMAIL=""
# Куда слать заявки (через запятую). Если пусто — используется NEXT_PUBLIC_CONTACT_EMAIL.
# CONTACT_TO_EMAIL="contact@bober-ai.dev"
# Несколько получателей: CONTACT_TO_EMAIL="contact@bober-ai.dev,admin@example.com"
# CONTACT_DRY_RUN=1

# Яндекс 360 — корпоративная почта (Яндекс Бизнес)
# OAuth: https://yandex.ru/dev/api360/doc/ru/access
# Права: directory:read_organization, directory:read_domains, directory:read_users, directory:write_users
# YANDEX_360_OAUTH_TOKEN=""
# YANDEX_360_CLIENT_ID=""
# YANDEX_360_CLIENT_SECRET=""
# YANDEX_360_ORG_ID=""
# YANDEX_360_DOMAIN="bober-ai.dev"
# YANDEX_360_MAILBOX_NICKNAME="contact"
# Shared mailbox ACL: npm run yandex360:mailbox -- shared-create
# Needs OAuth scopes: ya360_admin:mail_read_shared_mailbox_inventory,
# ya360_admin:mail_write_shared_mailbox_inventory (+ directory:read/write_*)
# YANDEX_360_GRANT_EMAIL="stasinskipawel@yandex.ru"
# YANDEX_360_SHARED_FALLBACK_NICKNAME="info"

# Selectel — почтовый сервис (SMTP relay, не inbox)
# SELECTEL_IAM_TOKEN=""
# SELECTEL_SERVICE_USER=""
# SELECTEL_SERVICE_PASSWORD=""
# SELECTEL_ACCOUNT_ID=""
# SELECTEL_PROJECT_NAME=""
# SELECTEL_DOMAIN="tony-ai.ru"
# SELECTEL_MAIL_FROM="hello@tony-ai.ru"
# SELECTEL_DKIM_VALUE=""

# YANDEX_OAUTH_TOKEN=""
# YANDEX_METRIKA_OAUTH_TOKEN=""
# YANDEX_METRIKA_COUNTER_NAME="Bober AI Systems"
# YANDEX_YTM_CONTAINER_ID=""  # ID контейнера YTM (если ≠ ID счётчика); npm run ytm:status
# npm run metrika:status  — снимок настроек счётчика и контентной аналитики
# npm run metrika:counter — создать/найти счётчик
# npm run ytm:status      — статус Тег Менеджера + галерея шаблонов (API только read)
# YANDEX_WEBMASTER_CLIENT_ID="f2e2f11ae7e3492886ad61a6e45a4c5c"
# YANDEX_WEBMASTER_CLIENT_SECRET=""
# ClientID/secret ≠ access token. Один раз: npm run webmaster:oauth  (или yaga webmaster oauth)

# Яндекс Вебмастер — дополненное представление в поиске β (категория «Исполнители»)
# OAuth: https://yandex.ru/dev/webmaster/doc/ru/tasks/how-to-get-oauth
# YANDEX_WEBMASTER_OAUTH_TOKEN=""
# YANDEX_WEBMASTER_REFRESH_TOKEN=""
# YANDEX_WEBMASTER_HOST_URL="https://www.bober-ai.dev"
# YANDEX_WEBMASTER_FEED_URL="https://www.bober-ai.dev/performers-feed.yml"
# YANDEX_WEBMASTER_FEED_TYPE="SERVICES"
# YANDEX_WEBMASTER_REGION_IDS="225"
# Микросайты (отдельные хосты + фиды): npm run webmaster:feed:upload -- --all
# YANDEX_WEBMASTER_BITRIX_HOST_URL="https://bitrix.bober-ai.dev"
# YANDEX_WEBMASTER_BITRIX_FEED_URL="https://bitrix.bober-ai.dev/performers-feed.yml"
# YANDEX_WEBMASTER_PARTNERS_HOST_URL="https://partners.bober-ai.dev"
# YANDEX_WEBMASTER_PARTNERS_FEED_URL="https://partners.bober-ai.dev/performers-feed.yml"

# Yandex Cloud Search API / Wordstat v2
# YANDEX_SEARCH_API_KEY=""
# YANDEX_SEARCH_FOLDER_ID=""
# YANDEX_FOLDER_ID=""
# YANDEX_CLOUD_ORGANIZATION_ID=""
# YANDEX_CLOUD_ORGANIZATION_NAME=""
# YANDEX_CLOUD_FOLDER_ID=""

# Yandex Direct API (OAuth app: direct wordstat)
# YANDEX_DIRECT_CLIENT_ID=""
# YANDEX_DIRECT_CLIENT_SECRET=""
# YANDEX_DIRECT_REDIRECT_URI="https://oauth.yandex.ru/verification_code"
# YANDEX_DIRECT_OAUTH_TOKEN=""
# YANDEX_DIRECT_REFRESH_TOKEN=""
# YANDEX_DIRECT_TOKEN_EXPIRES_AT=""
# npm run yandex:direct:campaigns -- status
# npm run yandex:direct:campaigns -- create-unified --dry-run
# «Мастер кампаний» через API недоступен — только ЕПК (UnifiedCampaign)
