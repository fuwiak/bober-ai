#!/usr/bin/env bash
# Launch yaga from anywhere (symlink-safe).
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  LINK="$(readlink "$SOURCE")"
  if [[ "$LINK" == /* ]]; then SOURCE="$LINK"; else SOURCE="$DIR/$LINK"; fi
done
HERE="$(cd "$(dirname "$SOURCE")" && pwd)"
exec node "$HERE/bin/yaga.js" "$@"
