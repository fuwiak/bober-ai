{
	email stasinskipawel@yandex.ru
	acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# HTTP — Railway healthchecks (any Host) + ACME HTTP-01 + apex/www redirect.
# Named HTTPS sites use :443 only so they don't overlap this listener.
# $PORT defaults to 80 (Dockerfile); Railway may override.
:{$PORT:80} {
	handle /api/health {
		header Content-Type text/plain
		respond "ok" 200
	}

	@siteHost host www.bober-ai.dev bober-ai.dev
	handle @siteHost {
		redir https://www.bober-ai.dev{uri} permanent
	}

	# Preview / private network (Railway): serve static over HTTP
	handle {
		encode gzip
		root * /srv
		try_files {path}.html {path}/index.html {path} /index.html
		file_server
	}
}

https://bober-ai.dev {
	redir https://www.bober-ai.dev{uri} permanent
}

https://www.bober-ai.dev {
	encode gzip
	root * /srv
	try_files {path}.html {path}/index.html {path} /index.html
	file_server

	# MIME for static export feeds
	mime {
		.yml application/xml
		.md text/markdown
		.txt text/plain
	}

	header /partners/ru.html X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
	header /tel* X-Robots-Tag "noindex, nofollow"
	header /performers-feed.yml X-Robots-Tag "noindex"
	header /performers-feed.yml Access-Control-Allow-Origin "*"
	header /performers-feed.yml Cache-Control "public, max-age=300"

	redir /ru / permanent
	redir /ru/ / permanent
	redir /ru.html / permanent
}
