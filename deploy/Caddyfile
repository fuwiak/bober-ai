{
	email stasinskipawel@yandex.ru
	acme_ca https://acme-v02.api.letsencrypt.org/directory
	# HTTP/3 (QUIC/UDP) often breaks behind VPNs — keep TCP only (h1/h2).
	servers {
		protocols h1 h2
	}
}

# HTTP — ACME HTTP-01 + apex/www redirect + health.
:{$PORT:80} {
	handle /api/health {
		header Content-Type text/plain
		respond "ok" 200
	}

	@siteHost host www.bober-ai.dev bober-ai.dev
	handle @siteHost {
		redir https://www.bober-ai.dev{uri} permanent
	}

	handle {
		encode gzip
		root * /srv
		try_files {path} {path}.html {path}/index.html =404
		file_server
	}

	handle_errors {
		root * /srv
		rewrite * /404.html
		file_server
	}
}

https://bober-ai.dev {
	redir https://www.bober-ai.dev{uri} permanent
}

https://www.bober-ai.dev {
	encode gzip
	root * /srv
	# Real 404 for unknown paths (no soft-404 via homepage rewrite).
	try_files {path} {path}.html {path}/index.html =404
	file_server

	handle_errors {
		rewrite * /404.html
		file_server
	}

	header /performers-feed.yml Content-Type "application/xml; charset=utf-8"
	header /info.md Content-Type "text/markdown; charset=utf-8"
	header /info.txt Content-Type "text/plain; charset=utf-8"

	header /partners/ru.html X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
	header /tel* X-Robots-Tag "noindex, nofollow"
	header /performers-feed.yml X-Robots-Tag "noindex"
	header /performers-feed.yml Access-Control-Allow-Origin "*"
	header /performers-feed.yml Cache-Control "public, max-age=300"

	redir /ru / permanent
	redir /ru/ / permanent
	redir /ru.html / permanent
}
