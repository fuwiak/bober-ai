{
  "name": "bober-ai-dev",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && node scripts/postbuild-static.mjs",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live": "playwright test -c playwright.live.config.ts",
    "webmaster:feed:upload": "node scripts/yandex-webmaster-feed.mjs",
    "webmaster:feed:status": "node scripts/yandex-status.mjs",
    "webmaster:mirrors": "node scripts/yandex-webmaster-mirrors.mjs",
    "yandex:status": "node scripts/yandex-status.mjs",
    "yandex:feed:repair": "node scripts/yandex-feed-repair.mjs",
    "yandex360:mailbox": "node scripts/yandex360-mailbox.mjs",
    "selectel:mail": "node scripts/selectel-email.mjs",
    "metrika:counter": "node scripts/yandex-metrika-counter.mjs",
    "metrika:status": "node scripts/yandex-metrika-status.mjs",
    "ytm:status": "node scripts/yandex-ytm-status.mjs",
    "yandex:wordstat": "node scripts/yandex-wordstat.mjs",
    "seo:generate-catalog": "node scripts/generate-seo-catalog.mjs",
    "yandex:direct:oauth": "node scripts/yandex-direct-oauth.mjs",
    "yandex:direct:oauth:refresh": "node scripts/yandex-direct-oauth.mjs refresh --update-railway",
    "yandex:direct:oauth:ensure": "node scripts/yandex-direct-oauth.mjs ensure --update-railway",
    "yandex:direct:campaigns": "node scripts/yandex-direct-campaigns.mjs",
    "ops": "npm run ops:tui",
    "ops:tui": "go run ./cli",
    "ops:status": "go run ./cli status",
    "ops:health": "go run ./cli health",
    "ops:logs": "go run ./cli logs",
    "ops:build": "go run ./cli build",
    "ops:install": "bash cli/install.sh",
    "yaga": "node cli/yaga/bin/yaga.js",
    "yaga:install": "bash cli/yaga/install.sh"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.5.0",
    "next-intl": "^4.13.2",
    "nodemailer": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
